{
  "info": {
    "name": "ReviewHub API",
    "description": "ReviewHub — Meta Ray-Ban Smart Glasses Review Intelligence Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@reviewhub.io\",\n  \"password\": \"securepass123\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@reviewhub.io\",\n  \"password\": \"securepass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "List Reviews (Paginated)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/reviews?page=1&limit=20&sortBy=date&order=desc",
              "host": ["{{base_url}}"],
              "path": ["reviews"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "sortBy", "value": "date" },
                { "key": "order", "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "Get Review by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/reviews/:id",
              "host": ["{{base_url}}"],
              "path": ["reviews", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        },
        {
          "name": "Search Reviews",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/reviews/search?q=smart+glasses&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["reviews", "search"],
              "query": [
                { "key": "q", "value": "smart glasses" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Create Review (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewID\": \"RTEST123\",\n  \"name\": \"TestUser\",\n  \"date\": \"2025-05-01\",\n  \"rating\": 5,\n  \"title\": \"Great glasses\",\n  \"review\": \"Amazing product\",\n  \"is_positive_review\": 1,\n  \"helpfulness_score\": 8.5\n}"
            },
            "url": {
              "raw": "{{base_url}}/reviews",
              "host": ["{{base_url}}"],
              "path": ["reviews"]
            }
          }
        },
        {
          "name": "Update Review (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated title\",\n  \"rating\": 4\n}"
            },
            "url": {
              "raw": "{{base_url}}/reviews/:id",
              "host": ["{{base_url}}"],
              "path": ["reviews", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        },
        {
          "name": "Delete Review (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/reviews/:id",
              "host": ["{{base_url}}"],
              "path": ["reviews", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Overview",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/analytics/overview",
              "host": ["{{base_url}}"],
              "path": ["analytics", "overview"]
            }
          }
        },
        {
          "name": "Rating Distribution",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/analytics/rating-distribution",
              "host": ["{{base_url}}"],
              "path": ["analytics", "rating-distribution"]
            }
          }
        },
        {
          "name": "Sentiment Trend",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/analytics/sentiment-trend",
              "host": ["{{base_url}}"],
              "path": ["analytics", "sentiment-trend"]
            }
          }
        },
        {
          "name": "Top Reviewers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/analytics/top-reviewers",
              "host": ["{{base_url}}"],
              "path": ["analytics", "top-reviewers"]
            }
          }
        },
        {
          "name": "Helpfulness Distribution",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/analytics/helpfulness-distribution",
              "host": ["{{base_url}}"],
              "path": ["analytics", "helpfulness-distribution"]
            }
          }
        },
        {
          "name": "Monthly Volume",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/analytics/monthly-volume",
              "host": ["{{base_url}}"],
              "path": ["analytics", "monthly-volume"]
            }
          }
        },
        {
          "name": "Image vs No Image",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/analytics/image-vs-no-image",
              "host": ["{{base_url}}"],
              "path": ["analytics", "image-vs-no-image"]
            }
          }
        }
      ]
    }
  ]
}
